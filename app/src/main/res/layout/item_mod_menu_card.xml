<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="132dp"
    android:layout_margin="8dp"
    android:defaultFocusHighlightEnabled="false"
    app:cardBackgroundColor="#24282C"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/mod_card_icon"
                android:layout_width="30dp"
                android:layout_height="30dp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/mod_card_favorite"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:defaultFocusHighlightEnabled="false"
                android:padding="5dp"
                android:src="@drawable/ic_star"
                android:tint="#A8B0B8" />

        </LinearLayout>

        <TextView
            android:id="@+id/mod_card_name"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="#F1F4F6"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/mod_card_status"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:background="@drawable/bg_mod_status_disabled"
                android:gravity="center"
                android:minWidth="58dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="10sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/mod_card_config"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:defaultFocusHighlightEnabled="false"
                android:padding="5dp"
                android:src="@drawable/ic_settings"
                android:tint="#A8B0B8" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
