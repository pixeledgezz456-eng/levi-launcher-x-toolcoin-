<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <androidx.cardview.widget.CardView
        android:id="@+id/mod_menu_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_marginStart="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="#FA181A1D"
        app:cardCornerRadius="14dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="150dp"
                android:layout_height="match_parent"
                android:background="#151719"
                android:orientation="vertical"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="14dp"
                    android:contentDescription="@string/app_name"
                    android:src="@mipmap/ic_launcher" />

                <TextView
                    android:id="@+id/nav_modules"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackground"
                    android:defaultFocusHighlightEnabled="false"
                    android:drawableStart="@drawable/ic_modules"
                    android:drawablePadding="8dp"
                    android:drawableTint="#4AE0A0"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:text="@string/mod_menu_modules"
                    android:textColor="#4AE0A0"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nav_hud_editor"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:alpha="0.6"
                    android:background="?attr/selectableItemBackground"
                    android:defaultFocusHighlightEnabled="false"
                    android:drawableStart="@drawable/ic_edit"
                    android:drawablePadding="8dp"
                    android:drawableTint="#A8B0B8"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:text="@string/mod_menu_hud_editor"
                    android:textColor="#A8B0B8"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/nav_settings"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:alpha="0.6"
                    android:background="?attr/selectableItemBackground"
                    android:defaultFocusHighlightEnabled="false"
                    android:drawableStart="@drawable/ic_settings"
                    android:drawablePadding="8dp"
                    android:drawableTint="#A8B0B8"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:text="@string/settings"
                    android:textColor="#A8B0B8"
                    android:textSize="13sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="#1C1F22"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <LinearLayout
                        android:id="@+id/search_container"
                        android:layout_width="0dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_search_field"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_search"
                            android:tint="#A8B0B8" />

                        <EditText
                            android:id="@+id/search_input"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="@string/mod_menu_search_hint"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:singleLine="true"
                            android:textColor="#F1F4F6"
                            android:textColorHint="#8F979F"
                            android:textSize="12sp" />

                        <ImageButton
                            android:id="@+id/btn_clear_search"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="3dp"
                            android:src="@drawable/ic_close"
                            android:tint="#A8B0B8"
                            android:visibility="gone" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/config_header"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <ImageButton
                            android:id="@+id/btn_back_to_modules"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:src="@drawable/ic_arrow_back"
                            android:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/config_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_close_menu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_close_button"
                        android:padding="8dp"
                        android:src="@drawable/ic_close"
                        android:tint="#FFFFFF" />

                </LinearLayout>

                <HorizontalScrollView
                    android:id="@+id/filter_bar"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="#1C1F22"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/filter_all"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_search_field"
                            android:defaultFocusHighlightEnabled="false"
                            android:gravity="center"
                            android:minWidth="58dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="@string/filter_all"
                            android:textColor="#4AE0A0"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/filter_favorites"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_search_field"
                            android:defaultFocusHighlightEnabled="false"
                            android:gravity="center"
                            android:minWidth="72dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="@string/mod_menu_favorites"
                            android:textColor="#A8B0B8"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/filter_enabled"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_search_field"
                            android:defaultFocusHighlightEnabled="false"
                            android:gravity="center"
                            android:minWidth="72dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="@string/mod_menu_filter_enabled"
                            android:textColor="#A8B0B8"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/filter_inbuilt"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_search_field"
                            android:defaultFocusHighlightEnabled="false"
                            android:gravity="center"
                            android:minWidth="72dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="@string/mod_menu_filter_inbuilt"
                            android:textColor="#A8B0B8"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/filter_external"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_search_field"
                            android:defaultFocusHighlightEnabled="false"
                            android:gravity="center"
                            android:minWidth="72dp"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="@string/mod_menu_filter_external"
                            android:textColor="#A8B0B8"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/module_count_text"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:textColor="#A8B0B8"
                            android:textSize="11sp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#343A40" />

                <FrameLayout
                    android:id="@+id/modules_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/mods_grid_recycler"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:defaultFocusHighlightEnabled="false"
                        android:focusable="false"
                        android:clipToPadding="false"
                        android:padding="14dp" />

                    <LinearLayout
                        android:id="@+id/empty_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_modules"
                            android:tint="#333333" />

                        <TextView
                            android:id="@+id/empty_state_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/mod_menu_no_mods"
                            android:textColor="#555555"
                            android:textSize="12sp" />

                    </LinearLayout>

                </FrameLayout>

                <ScrollView
                    android:id="@+id/settings_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:alpha="0.8"
                            android:text="@string/mod_menu_general_settings"
                            android:textAllCaps="true"
                            android:textColor="#4AE0A0"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/setting_notifications"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_mod_status_disabled"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_notifications"
                                android:tint="#888888" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/mod_menu_notifications"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/mod_menu_notifications_desc"
                                    android:textColor="#888888"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <Switch
                                android:id="@+id/switch_notifications"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="#4AE0A0"
                                android:trackTint="@color/switch_track_color" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/setting_pause_menu_only"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_mod_status_disabled"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_hud"
                                android:tint="#888888" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/mod_menu_pause_menu_only"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/mod_menu_pause_menu_only_desc"
                                    android:textColor="#888888"
                                    android:textSize="11sp" />

                            </LinearLayout>

                            <Switch
                                android:id="@+id/switch_pause_menu_only"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="#4AE0A0"
                                android:trackTint="@color/switch_track_color" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="16dp"
                            android:background="#2A2A2A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:alpha="0.8"
                            android:text="@string/mod_menu_appearance"
                            android:textAllCaps="true"
                            android:textColor="#4AE0A0"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/setting_mod_menu_opacity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_mod_status_disabled"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_modules"
                                    android:tint="#888888" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:text="@string/mod_menu_opacity"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_mod_menu_opacity"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/mod_menu_default_percent"
                                    android:textColor="#4AE0A0"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <SeekBar
                                android:id="@+id/seekbar_mod_menu_opacity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:max="100"
                                android:min="70"
                                android:progress="100"
                                android:progressTint="#4AE0A0"
                                android:thumbTint="#4AE0A0" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/setting_mod_menu_button_opacity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_mod_status_disabled"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_leaf_logo"
                                    android:tint="#888888" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:text="@string/mod_menu_button_opacity"
                                    android:textColor="#FFFFFF"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_mod_menu_button_opacity"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/mod_menu_default_percent"
                                    android:textColor="#4AE0A0"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <SeekBar
                                android:id="@+id/seekbar_mod_menu_button_opacity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:max="100"
                                android:min="0"
                                android:progress="100"
                                android:progressTint="#4AE0A0"
                                android:thumbTint="#4AE0A0" />

                        </LinearLayout>

                    </LinearLayout>
                </ScrollView>

                <LinearLayout
                    android:id="@+id/mod_config_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fillViewport="true">

                        <LinearLayout
                            android:id="@+id/mod_config_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp" />
                    </ScrollView>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/hud_editor_tools"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FA181A1D"
        app:cardCornerRadius="14dp"
        app:cardElevation="10dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_hud"
                    android:tint="#4AE0A0" />

                <TextView
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="@string/mod_menu_hud_editor"
                    android:textColor="#F1F4F6"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_hud_save"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_mod_status_disabled"
                    android:contentDescription="@string/save"
                    android:padding="8dp"
                    android:src="@drawable/ic_check"
                    android:tint="#4AE0A0" />

                <ImageButton
                    android:id="@+id/btn_hud_reset"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_mod_status_disabled"
                    android:contentDescription="@string/reset"
                    android:padding="8dp"
                    android:src="@drawable/ic_delete"
                    android:tint="#FF6B6B" />

                <ImageButton
                    android:id="@+id/btn_hud_cancel"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_close_button"
                    android:contentDescription="@string/cancel"
                    android:padding="8dp"
                    android:src="@drawable/ic_close"
                    android:tint="#FFFFFF" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_hud_button_size"
                    android:layout_width="82dp"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_button_size"
                    android:textColor="#4AE0A0"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekbar_hud_button_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:min="20"
                    android:progress="56"
                    android:progressTint="#4AE0A0"
                    android:thumbTint="#4AE0A0" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
