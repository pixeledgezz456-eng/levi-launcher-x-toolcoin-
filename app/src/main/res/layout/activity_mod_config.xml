<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/mod_config_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="15dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="0dp">

            <TextView
                android:id="@+id/mod_config_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/misans"
                android:maxLines="1"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/mod_config_file_spinner"
                android:layout_width="220dp"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_spinner_outline"
                android:visibility="gone" />

            <Button
                android:id="@+id/mod_config_save_button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="22dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:background="@drawable/bg_launch_button"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/misans"
                android:text="@string/save"
                android:textAllCaps="false"
                android:textColor="@color/on_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mod_config_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:padding="0dp" />

            <ProgressBar
                android:id="@+id/mod_config_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/mod_config_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/misans"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
