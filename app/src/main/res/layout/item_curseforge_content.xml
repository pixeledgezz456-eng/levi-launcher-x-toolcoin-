<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:padding="16dp"
    android:background="@drawable/bg_rounded_card"
    android:elevation="4dp"
    android:foreground="?android:attr/selectableItemBackground">

    <ImageView
        android:id="@+id/mod_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_minecraft_cube"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/mod_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:ellipsize="end"
        android:fontFamily="@font/misans"
        android:maxLines="1"
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/mod_icon"
        app:layout_constraintTop_toTopOf="@id/mod_icon"
        tools:text="Furnicraft Addon" />

    <TextView
        android:id="@+id/mod_author"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="@font/misans"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/mod_title"
        app:layout_constraintTop_toBottomOf="@id/mod_title"
        tools:text="by RobertGamer69" />

    <TextView
        android:id="@+id/mod_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="@font/misans"
        android:maxLines="2"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/mod_title"
        app:layout_constraintTop_toBottomOf="@id/mod_author"
        tools:text="The best furniture addon for Minecraft Bedrock! Contains over 500 pieces of furniture." />

    <TextView
        android:id="@+id/mod_metadata"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="@font/misans"
        android:maxLines="1"
        android:textColor="@color/primary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/mod_title"
        app:layout_constraintTop_toBottomOf="@id/mod_description"
        tools:text="1.2M Downloads • Updated Oct 24 • Addons" />

</androidx.constraintlayout.widget.ConstraintLayout>
