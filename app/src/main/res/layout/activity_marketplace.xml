<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/surface"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_down"
                android:rotation="90"
                app:tint="@color/on_surface"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/marketplace_title"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/misans"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:ellipsize="end"/>

        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_input_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/marketplace_search_hint"
            app:boxBackgroundColor="@color/surface_variant"
            app:boxStrokeColor="@color/primary"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_search"
            app:endIconTint="@color/primary"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant"
                android:fontFamily="@font/misans"
                android:textSize="14sp"/>

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/results_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.6"
            android:fontFamily="@font/misans"
            android:textColor="@color/on_surface"
            android:textSize="11sp"
            tools:text="923 results"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@color/on_surface"
            android:alpha="0.08"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/generate_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:enabled="false"
            android:text="@string/inject_dlc"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/marketplace_filter_label"
            android:textColor="@color/on_surface"
            android:textSize="11sp"
            android:alpha="0.55"
            android:fontFamily="@font/misans"
            android:letterSpacing="0.08"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fadeScrollbars="true"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            tools:ignore="NestedWeights">

        <LinearLayout
            android:id="@+id/filter_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/nav_all"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/nav_item_background_selected"
                android:clickable="true"
                android:focusable="true">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/filter_icon"
                        app:tint="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/filter_all"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>

                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_addon"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="2dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/addon_icon"
                        app:tint="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/filter_addon"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>

                </LinearLayout>

            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_world"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="2dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/world_icon"
                        app:tint="@color/on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="@string/filter_world"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_skin"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="2dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/skin_icon"
                        app:tint="@color/on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="@string/filter_skin"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_texture"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="2dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/texture_icon"
                        app:tint="@color/on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="@string/filter_texture"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_mashup"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="2dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/mashup_icon"
                        app:tint="@color/on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="@string/filter_mashup"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_persona"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="2dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/persona_icon"
                        app:tint="@color/on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="@string/filter_persona"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/nav_emote"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="2dp">
                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@color/primary" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/emote_icon"
                        app:tint="@color/on_surface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="@string/filter_emotes"
                        android:textColor="@color/on_surface"
                        android:alpha="0.7"
                        android:fontFamily="@font/misans"
                        android:textSize="13sp"/>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/results_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:scrollbarStyle="outsideOverlay"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_search_result"/>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_search"
                app:tint="@color/on_surface"
                android:alpha="0.25"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/marketplace_empty"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:alpha="0.45"
                android:fontFamily="@font/misans"/>

        </LinearLayout>
    </FrameLayout>
</LinearLayout>